# ════════════════════════════════════════════════════════════════════════════
#  FRONTEND .env  —  read by Vite at build time
#  Copy to .env and fill in your values.
#  NOTE: All VITE_* vars are baked into the JS bundle at build time.
#        Re-build the frontend whenever you change these.
# ════════════════════════════════════════════════════════════════════════════

# Backend URL (must be reachable from the user's browser)
# Local dev:  http://localhost:8000
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000

# LiveKit server URL (wss://...)
# Get from: https://cloud.livekit.io → your project → Settings
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
