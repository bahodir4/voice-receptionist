# ════════════════════════════════════════════════════════════════════════════
#  ROOT .env  —  read by docker-compose
#  Copy to .env and fill in your values.
# ════════════════════════════════════════════════════════════════════════════

# ── MongoDB auth (Docker only) ────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme123          # ← change this!
MONGO_EXPOSED_PORT=27017                 # host port MongoDB is published on
MONGODB_DB_NAME=voice_receptionist

# ── Host ports ────────────────────────────────────────────────────────────
BACKEND_PORT=8000                        # FastAPI exposed on host
FRONTEND_PORT=3000                       # Nginx/frontend exposed on host

# ── Frontend build-time config (Vite bakes these into the JS bundle) ──────
# For Docker: use your server's public IP/domain
VITE_API_URL=http://localhost:8000
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
