# ════════════════════════════════════════════════════════════════════════════
#  BACKEND .env  —  read by FastAPI app and the Agent worker
#  Copy to .env and fill in your values.
# ════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── MongoDB Atlas (3rd-party) ─────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → your cluster → Connect → Drivers
# Format:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/voice_receptionist?retryWrites=true&w=majority
MONGODB_DB_NAME=voice_receptionist

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-32-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=30

# ── SMTP / Email ──────────────────────────────────────────────────────────
# Gmail: enable 2FA → create App Password at myaccount.google.com/apppasswords
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME=Voice Receptionist
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
DEBUG=true

# ── LiveKit ───────────────────────────────────────────────────────────────
# Get from: https://cloud.livekit.io → your project → Settings
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Groq LLM ─────────────────────────────────────────────────────────────
# Get from: https://console.groq.com
GROK_API_KEY=
GROK_BASE_URL=https://api.groq.com/openai/v1
GROK_MODEL=llama-3.3-70b-versatile

# ── ElevenLabs ────────────────────────────────────────────────────────────
# Get from: https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Twilio ────────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=                         # E.164, e.g. +12025550001

# ── LiveKit SIP (one-time setup — see README) ─────────────────────────────
# LIVEKIT_SIP_DOMAIN shown in LiveKit console → SIP settings
LIVEKIT_SIP_DOMAIN=
LIVEKIT_SIP_INBOUND_TRUNK_ID=
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
TWILIO_SIP_USERNAME=
TWILIO_SIP_PASSWORD=
